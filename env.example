# 이 파일을 복사해서 .env로 만들고 실제 발급받은 키를 채워넣으세요.
# .env는 .gitignore에 포함되어 있어 GitHub에 올라가지 않습니다.
#
#   cp .env.example .env
#
# 로컬 개발 시에는 .env를 python-dotenv 등으로 읽거나,
# 터미널에서 export로 직접 설정해서 사용하세요.
# PlayMCP 배포 시에는 이 값들을 PlayMCP 콘솔의 환경변수 설정 화면에 입력합니다
# (Git 소스 빌드 팝업 자체에는 환경변수 입력란이 없으므로, 서버 등록 후
#  상세정보 페이지에서 환경변수 설정 메뉴가 있는지 확인하세요).

# 온통청년(youthcenter.go.kr) 청년정책 오픈API 인증키
YOUTHCENTER_API_KEY=

# 공공데이터포털(data.go.kr) 인증키 (Decoding 키 사용)
# 국토부 아파트/오피스텔/연립다세대/단독다가구 전월세 실거래가 4종 + LH 임대주택단지 조회, 전부 이 키 하나로 사용
PUBLIC_DATA_API_KEY=
